# -------------------------------------------------------------------
# Figma API
# -------------------------------------------------------------------
# Required: Personal access token from https://www.figma.com/settings
FIGMA_ACCESS_TOKEN=your-figma-personal-access-token

# Optional: override for testing/proxies
FIGMA_API_BASE_URL=https://api.figma.com/v1

# -------------------------------------------------------------------
# MCP Server
# -------------------------------------------------------------------
MCP_HOST=0.0.0.0
MCP_PORT=8000

# Optional: if set, MCP clients must pass "Authorization: Bearer <token>"
# Leave empty to allow unauthenticated connections (suitable for local use)
MCP_AUTH_TOKEN=

# -------------------------------------------------------------------
# Cache
# -------------------------------------------------------------------
CACHE_TTL_SECONDS=300

# Optional: Redis URL for persistent cache (in-memory used if not set)
# REDIS_URL=redis://localhost:6379/0

# -------------------------------------------------------------------
# App
# -------------------------------------------------------------------
DEBUG=false
LOG_LEVEL=INFO

# -------------------------------------------------------------------
# Testing (integration tests only)
# -------------------------------------------------------------------
# FIGMA_TEST_FILE_KEY=your-test-file-key
