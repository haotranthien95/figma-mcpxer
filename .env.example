# -------------------------------------------------------------------
# Figma API
# -------------------------------------------------------------------
# Required: Personal access token from https://www.figma.com/settings
FIGMA_ACCESS_TOKEN=your-figma-personal-access-token

# Optional: override for testing/proxies
FIGMA_API_BASE_URL=https://api.figma.com/v1

# -------------------------------------------------------------------
# MCP Server
# -------------------------------------------------------------------
MCP_HOST=0.0.0.0
MCP_PORT=8000

# Optional: if set, MCP clients must pass "Authorization: Bearer <token>"
# Leave empty to allow unauthenticated connections (suitable for local use)
MCP_AUTH_TOKEN=

# -------------------------------------------------------------------
# Cache
# -------------------------------------------------------------------
CACHE_TTL_SECONDS=300

# Optional: Redis URL for shared persistent cache across replicas.
# In-memory cache is used when this is not set.
# Requires: pip install figma-mcpxer[redis]
# REDIS_URL=redis://localhost:6379/0

# -------------------------------------------------------------------
# Phase 8 — Webhooks
# -------------------------------------------------------------------
# Secret passcode that Figma includes in every webhook delivery.
# Must match the passcode used when registering the webhook.
# Leave empty to skip passcode validation (dev only).
# FIGMA_WEBHOOK_PASSCODE=change-me-in-production

# -------------------------------------------------------------------
# Phase 9 — Production Hardening
# -------------------------------------------------------------------
# Rate limit: max requests per second per client IP. 0 = disabled.
RATE_LIMIT_RPS=60

# Log format: "text" for human-readable (dev), "json" for structured (prod)
LOG_FORMAT=text

# -------------------------------------------------------------------
# App
# -------------------------------------------------------------------
DEBUG=false
LOG_LEVEL=INFO

# -------------------------------------------------------------------
# Testing (integration tests only)
# -------------------------------------------------------------------
# FIGMA_TEST_FILE_KEY=your-test-file-key
